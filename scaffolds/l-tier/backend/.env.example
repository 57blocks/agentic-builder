# ─── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string. Required.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Enable PG SSL (only set "true" for managed cloud DBs that require it).
DB_SSL=false

# ─── Sequelize sync (schema = models) ────────────────────────────────────────
# There are no migrations: the Sequelize models are the single source of truth.
# `syncModels()` runs a bare `sync()` on startup, which CREATEs any missing
# tables straight from the model definitions. Two optional escape hatches for
# local model iteration (leave both unset in CI / preview — the DB is fresh):
#   DB_SYNC_FORCE=true → DROP & recreate every table on boot (clean rebuild)
#   DB_SYNC_ALTER=true → ALTER existing tables to match models (use sparingly;
#                        re-runs DDL every boot and can surface latent model
#                        default errors, e.g. `defaultValue: {}` on JSONB).
DB_SYNC_FORCE=false
DB_SYNC_ALTER=false

# ─── TimescaleDB (optional) ───────────────────────────────────────────────────
# Set to 1 if your Postgres does NOT have the TimescaleDB extension
# installed — this is the common case for Homebrew, dev Docker images,
# GitHub Actions runners, and most cloud preview DBs.
#
# When disabled: migrations that would create hypertables fall back to
# plain Postgres tables. Queries still work, you just lose Timescale's
# perf optimisations for time-series scans.
#
# Recommendation: keep TIMESCALE_DISABLED=1 for local dev. Flip to 0 (or
# unset) only when you have Timescale installed AND you intentionally
# want the perf benefit.
TIMESCALE_DISABLED=1

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowlist of trusted origins (scheme + host + port,
# matched verbatim against the request's `Origin` header). When unset and
# NODE_ENV != production, the middleware falls back to http://localhost:5173.
#
# In production, the backend refuses to boot if BOTH `CORS_ORIGINS` and the
# legacy `FRONTEND_URL` are missing (see `src/config/env.ts`).
#
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:5173

# ─── Observability ────────────────────────────────────────────────────────────
# pino log level: trace | debug | info | warn | error | fatal | silent
# Defaults: development → "debug", production → "info"
LOG_LEVEL=debug

# ─── JWT auth ─────────────────────────────────────────────────────────────────
# Canonical variable consumed by the `auth-password-rbac` / `auth-magic-link`
# scaffolds (see `src/utils/jwt.ts#readSecret`). Must be ≥ 32 chars in
# production; the backend will refuse to boot otherwise.
#
# Generate a strong value with:  openssl rand -hex 32
AUTH_JWT_SECRET=replace-me-with-a-32-byte-random-string-min-32-chars-long
AUTH_JWT_EXPIRES_IN=7d

# ─── Queue / background workers ───────────────────────────────────────────────
# L-tier ships an in-process queue (Promise + EventEmitter) so `pnpm dev` works
# without Redis. Flip USE_REDIS_QUEUE=1 to route through BullMQ instead — the
# same enqueueJob / registerWorker API; only the backing store changes.
#
# When USE_REDIS_QUEUE=1 is set, REDIS_URL MUST point at a reachable Redis.
USE_REDIS_QUEUE=0
REDIS_URL=redis://localhost:6379

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Default in-memory rate limit applied to expensive endpoints. For multi-replica
# deploys swap to a Redis-backed limiter; the middleware API stays the same.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

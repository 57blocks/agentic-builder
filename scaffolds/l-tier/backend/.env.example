# ─── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string. Required.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Enable PG SSL (only set "true" for managed cloud DBs that require it).
DB_SSL=false

# ─── Migration runner ─────────────────────────────────────────────────────────
# When set to "1" (default), `initDb()` runs every pending migration under
# `src/database/migrations/` on backend startup via umzug. Set to "0" for
# production deploys where migrations should be applied as an explicit
# release step via `pnpm migrate`.
AUTO_MIGRATE=1

# ─── Sequelize sync ──────────────────────────────────────────────────────────
# Migrations are the source of truth for schema changes. `syncModels()` defaults
# to `sync({ alter: false })`. Set to "true" ONLY for a quick local sync of
# model definitions to the dev DB without writing a migration — this re-runs
# DDL on every boot and surfaces every latent error in model defaults (e.g.
# `defaultValue: {}` on JSONB columns crashes Sequelize). Never enable in
# production.
DB_SYNC_ALTER=false

# ─── TimescaleDB (optional) ───────────────────────────────────────────────────
# Set to 1 if your Postgres does NOT have the TimescaleDB extension
# installed — this is the common case for Homebrew, dev Docker images,
# GitHub Actions runners, and most cloud preview DBs.
#
# When disabled: migrations that would create hypertables fall back to
# plain Postgres tables. Queries still work, you just lose Timescale's
# perf optimisations for time-series scans.
#
# Recommendation: keep TIMESCALE_DISABLED=1 for local dev. Flip to 0 (or
# unset) only when you have Timescale installed AND you intentionally
# want the perf benefit.
TIMESCALE_DISABLED=1

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Observability ────────────────────────────────────────────────────────────
# pino log level: trace | debug | info | warn | error | fatal | silent
# Defaults: development → "debug", production → "info"
LOG_LEVEL=debug

# ─── JWT auth ─────────────────────────────────────────────────────────────────
# AUTH_JWT_SECRET is REQUIRED in production (≥16 chars). `assertRequiredEnv()`
# fatal-exits the process at boot when missing or too short. Generate with:
#   openssl rand -hex 32
#
# Legacy alias `JWT_SECRET` is still accepted with a one-time deprecation
# warning to ease migration. Drop it after every consumer has switched over.
AUTH_JWT_SECRET=replace-me-with-a-32-byte-random-string-from-openssl-rand
AUTH_JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowlist of origins (scheme + host + port, no trailing /).
# Wildcards are intentionally NOT supported — a misconfigured `*` in
# production lets any origin issue credentialed requests against your API.
# Required in production; in dev, omitting it falls back to localhost:5173.
CORS_ORIGINS=http://localhost:5173

# ─── Queue / background workers ───────────────────────────────────────────────
# L-tier ships an in-process queue (Promise + EventEmitter) so `pnpm dev` works
# without Redis. Flip USE_REDIS_QUEUE=1 to route through BullMQ instead — the
# same enqueueJob / registerWorker API; only the backing store changes.
#
# When USE_REDIS_QUEUE=1 is set, REDIS_URL MUST point at a reachable Redis.
USE_REDIS_QUEUE=0
REDIS_URL=redis://localhost:6379

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Default in-memory rate limit applied to expensive endpoints. For multi-replica
# deploys swap to a Redis-backed limiter; the middleware API stays the same.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

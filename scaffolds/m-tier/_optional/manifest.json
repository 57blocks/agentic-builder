{
  "$schema": "./manifest.schema.json",
  "version": 2,
  "description": "Optional scaffold features for the M-tier template. Each entry is copied into the generated project when (a) `.blueprint/auth-decision.json` selects it via the `authMode` field (auth scaffolds only), OR (b) the kickoff-detected ResourceRequirement[] declares ANY of its triggerEnvKeys (legacy path — presence of the declaration is enough). Mutually-exclusive groups: at most one `authMode` feature is applied per project.",
  "features": {
    "auth-password-rbac": {
      "label": "Email + Password + RBAC (admin / operator / viewer)",
      "authMode": "password-rbac",
      "triggerEnvKeys": [],
      "extraDeps": {
        "backend": {
          "bcryptjs": "^2.4.3",
          "jsonwebtoken": "^9.0.2",
          "@types/bcryptjs": "^2.4.6",
          "@types/jsonwebtoken": "^9.0.5"
        },
        "frontend": {
          "zustand": "^4.5.0"
        }
      }
    },
    "auth-magic-link": {
      "label": "Magic Link (passwordless, SMTP)",
      "authMode": "magic-link",
      "triggerEnvKeys": [
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_USER",
        "SMTP_PASSWORD",
        "SMTP_FROM"
      ],
      "extraDeps": {
        "backend": {
          "jsonwebtoken": "^9.0.2",
          "@types/jsonwebtoken": "^9.0.5",
          "nodemailer": "^6.9.16",
          "@types/nodemailer": "^6.4.17"
        },
        "frontend": {
          "zustand": "^4.5.0"
        }
      }
    },
    "auth-privy": {
      "label": "Privy OAuth (server + client SDK)",
      "authMode": "privy",
      "triggerEnvKeys": [
        "VITE_PRIVY_APP_ID",
        "NEXT_PUBLIC_PRIVY_APP_ID",
        "PRIVY_APP_ID",
        "PRIVY_APP_SECRET"
      ],
      "extraDeps": {
        "frontend": {
          "@privy-io/react-auth": "^3.22.0"
        },
        "backend": {
          "@privy-io/node": "^0.16.0"
        }
      }
    },
    "auth-clerk": {
      "label": "Clerk OAuth (server + client SDK)",
      "triggerEnvKeys": [
        "VITE_CLERK_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
        "CLERK_SECRET_KEY"
      ],
      "extraDeps": {
        "frontend": {
          "@clerk/clerk-react": "^5.0.0"
        },
        "backend": {
          "@clerk/backend": "^1.0.0"
        }
      }
    },
    "payment-stripe": {
      "label": "Stripe payments (server SDK + webhooks)",
      "triggerEnvKeys": [
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "VITE_STRIPE_PUBLISHABLE_KEY"
      ],
      "extraDeps": {
        "backend": {
          "stripe": "^17.0.0"
        }
      }
    }
  }
}

scaffolds/**/node_modules
# generated-code output and runtime artifacts
/generated-code/*
/generated-code/.ralph/
example
/.pnp
.pnp.*
.yarn/*
.memory/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

*.zip
Engineering
# next.js
/.next/
/.next-*/
/out/

# parallel-instance generated-code roots (kept untracked alongside generated-code/)
/generated-code-*/

# electron
/dist/

# env files
/.env
/.env.local
/.env*.local
/.env.parallel

# testing
/coverage

# pipeline snapshot (debug-only, may contain large doc content)
.blueprint/pipeline-snapshot.json
.blueprint/design-references/
.blueprint/kickoff-repo.json
.blueprint/kickoff-database.json

# shared-schema is generated per-project and should not be tracked
.blueprint/shared-schema.ts

# resource-requirements contains user-provided API key values
.blueprint/resource-requirements.json
.blueprint/auth-decision.json

# per-run orchestration/session runtime state + generated project workspaces
# (regenerated each run; not source — and often carry another project's content
# since .blueprint is shared across projects)
.blueprint/orchestration-status.json
.blueprint/last-coding-session.json
.blueprint/projects/

# misc
*.pem
.DS_Store
*.tsbuildinfo
next-env.d.ts

worklog-automation

# memory runtime / locks (L1 records under .memory/records are tracked separately)
.memory/.lock-target
.memory/metrics.json
.memory/trace.jsonl
docs/superpowers
CLAUDE.md

# infra provisioning artifacts (contain real DB / Redis credentials)
.blueprint/kickoff-infra.json
.blueprint/kickoff-database.json
.claude/settings.json
.claude/scheduled_tasks.lock

# AI
.trae/

# runtime-captured project cover screenshots (user data, regenerated on demand)
public/project-covers/

# agentic-build channel: generated project workspaces (user output, not source)
agentic-builds/

# Per-task frontend context dumps written by frontend-context-logger.ts
/.logs/
# Per-project runtime design references (uploaded screenshots + blueprint cache)
.blueprint/projects/
# Ad-hoc comparison screenshots dropped at the repo root (PixPin exports, scratch shots)
/*.png

.projects/
run.log

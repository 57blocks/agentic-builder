# Use a flat (npm-like) node_modules layout. pnpm's default nested `.pnpm`
# layout makes Next 16's enhanced-resolve build a colon-joined module-path
# string from next's deeply nested location, which breaks resolving the CSS
# `@import "tailwindcss"` (Can't resolve 'tailwindcss') and triggers a runaway
# scan / OOM under `next dev`. A hoisted layout restores the npm-style flat
# node_modules where these tools resolve correctly.
node-linker=hoisted
